{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2022",
    "types": ["vite/client"]
  },
  "include": [
    "VRX-64-web/web-preview/src/**/*",
    "VRX-64-native/src/ui/management/**/*",
    "VRX-64-web/web-preview/vite.config.ts",
    "VRX-64-native/src/ui/vite.config.ts"
  ]
}
